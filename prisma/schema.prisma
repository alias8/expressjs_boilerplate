// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id       String   @id @default(uuid())
  username      String   @unique
  password_hash String
  created_at    DateTime @default(now())
  Driver        Driver[]
  tripsAsRider  Trip[]   @relation("TripRider")
  tripsAsDriver Trip[]   @relation("TripDriver")
}

model Driver {
  driver_id String @id @default(uuid())

  user_id String // FK column — matches User.user_id type (String)
  user    User   @relation(fields: [user_id], references: [user_id])

  looking_for_trip Boolean
  vehicle_plate    String
}

model Trip {
  id                String     @id @default(uuid())
  startGPSLatitude  Decimal    @db.Decimal(9, 6)
  startGPSLongitude Decimal    @db.Decimal(9, 6)
  endGPSLatitude    Decimal    @db.Decimal(9, 6)
  endGPSLongitude   Decimal    @db.Decimal(9, 6)
  requested_at      DateTime
  accepted_at       DateTime?
  status            TripStatus
  ratingForDriver   Rating?
  ratingForRider    Rating?

  rider_id     String // FK column — matches User.user_id type (String)
  requested_by User   @relation("TripRider", fields: [rider_id], references: [user_id])

  driver_id   String? // FK column — matches User.user_id type (String)
  accepted_by User?   @relation("TripDriver", fields: [driver_id], references: [user_id])
}

enum Rating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum TripStatus {
  REQUESTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
